# =====================================
# AI Provider Configuration (REQUIRED)
# =====================================
# Select which AI provider to use
# Options: openai, anthropic, google
AI_PROVIDER=openai

# API Keys - Set only the key for your selected provider
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# AI Model Configuration
# Optional: Override the default model for your provider
# Defaults: gpt-4-mini (OpenAI), claude-3-5-haiku-20241022 (Anthropic), gemini-1.5-flash (Google)
# AI_MODEL=gpt-4-mini

# AI Behavior Configuration
# Temperature: Controls randomness (0-2). 0 = deterministic, higher = more creative
# Default: 0 (recommended for web scraping tasks)
# AI_TEMPERATURE=0

# =====================================
# Browser Configuration (OPTIONAL)
# =====================================
# BROWSER_HEADLESS: Run browser in headless mode
# Default: false (shows browser window for debugging)
# BROWSER_HEADLESS=false

# BROWSER_SLOWMO: Slow down browser actions for observation (milliseconds)
# Default: 100 (useful for debugging what the scraper is doing)
# BROWSER_SLOWMO=100

# BROWSER_TIMEOUT: Page navigation timeout (milliseconds)
# Default: 30000 (30 seconds)
# BROWSER_TIMEOUT=30000

# BROWSER_CHANNEL: Browser channel to use (chrome, firefox, webkit, or chromium)
# Default: chromium
# BROWSER_CHANNEL=chromium
