{
  "name": "@hop/ibr",
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "ibr": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "server": "node src/server.js",
    "dev": "node --watch src/index.js",
    "browser:install": "npx playwright install",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run --config test/vitest.config.js",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest --config test/vitest.config.js",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/vitest run --config test/vitest.config.js test/unit/",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/vitest run --config test/vitest.config.js test/integration/",
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/vitest run --config test/vitest.config.js test/e2e/",
    "test:e2e:fast": "E2E_TAGS=fast node --experimental-vm-modules node_modules/.bin/vitest run --config test/vitest.config.js test/e2e/",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/vitest run --coverage --config test/vitest.config.js",
    "judge:e2e": "node src/commands/judge-e2e.js",
    "build":        "node scripts/build.mjs && node scripts/sea.mjs",
    "build:bundle": "node scripts/build.mjs",
    "build:sea":    "node scripts/sea.mjs"
  },
  "keywords": [
    "scraping",
    "playwright",
    "web-scraping"
  ],
  "author": "",
  "license": "ISC",
  "description": "Intent Browser Runtime - AI-powered instruction parser for automated web interactions",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.27.4",
    "postject": "1.0.0-alpha.6",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@boundaryml/baml": "latest",
    "ai": "^6.0.67",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.5.0",
    "node-html-parser": "^7.0.1",
    "playwright": "^1.52.0",
    "winston": "^3.17.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
